generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoomPhase {
  LOBBY
  DISCUSSION
  VOTING
  RESULTS
}

enum PlayerRole {
  CIVILIAN
  IMPOSTOR
}

enum WinnerTeam {
  CIVILIANS
  IMPOSTORS
}

model Room {
  id                 String        @id @default(cuid())
  code               String        @unique
  phase              RoomPhase     @default(LOBBY)
  hostId             String?       @unique
  matchCount         Int           @default(10) @map("wordCount")
  clueRoundCount     Int           @default(3) @map("roundCount")
  turnSeconds        Int           @default(30)
  impostorCount      Int           @default(1)
  matchNumber        Int           @default(1) @map("wordNumber")
  clueRoundNumber    Int           @default(1) @map("roundNumber")
  currentPlayerIndex Int           @default(0)
  turnEndsAt         DateTime?
  matchWinner        WinnerTeam?   @map("winner")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  host               Player?       @relation("RoomHost", fields: [hostId], references: [id], onDelete: SetNull)
  players            Player[]      @relation("RoomPlayers")
  votes              Vote[]
  clues              Clue[]
  matchWords         MatchWord[]
  matchResults       MatchResult[]

  @@index([phase, turnEndsAt])
}

model WordPair {
  id                     String      @id @default(cuid())
  civilianWord           String
  impostorWord           String
  normalizedCivilianWord String
  normalizedImpostorWord String
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  matchWords             MatchWord[]

  @@unique([normalizedCivilianWord, normalizedImpostorWord])
  @@index([isActive])
}

model MatchWord {
  id               String    @id @default(cuid())
  matchNumber      Int       @map("wordNumber")
  civilianWord     String
  impostorWord     String
  roomId           String
  sourceWordPairId String?
  room             Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sourceWordPair   WordPair? @relation(fields: [sourceWordPairId], references: [id], onDelete: SetNull)

  @@unique([roomId, matchNumber])
  @@unique([roomId, sourceWordPairId])
  @@index([roomId])
  @@map("RoomWord")
}

model Clue {
  id                String   @id @default(cuid())
  content           String
  normalizedContent String
  matchNumber       Int      @map("wordNumber")
  clueRoundNumber   Int      @map("roundNumber")
  createdAt         DateTime @default(now())
  roomId            String
  playerId          String
  room              Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId, matchNumber, clueRoundNumber])
  @@unique([roomId, matchNumber, normalizedContent])
  @@index([roomId])
}

model Player {
  id               String     @id @default(cuid())
  publicId         String     @default(uuid())
  sessionTokenHash String     @unique
  sessionExpiresAt DateTime
  lastSeenAt       DateTime   @default(now())
  name             String
  role             PlayerRole @default(CIVILIAN)
  isReady          Boolean    @default(false)
  createdAt        DateTime   @default(now())
  roomId           String
  room             Room       @relation("RoomPlayers", fields: [roomId], references: [id], onDelete: Cascade)
  hostedRoom       Room?      @relation("RoomHost")
  votes            Vote[]     @relation("Voter")
  received         Vote[]     @relation("Target")
  clues            Clue[]

  @@unique([roomId, publicId])
  @@index([roomId])
  @@index([lastSeenAt])
}

model Vote {
  id          String   @id @default(cuid())
  roomId      String
  voterId     String
  targetId    String
  matchNumber Int      @default(1)
  createdAt   DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  voter       Player   @relation("Voter", fields: [voterId], references: [id], onDelete: Cascade)
  target      Player   @relation("Target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([roomId, matchNumber, voterId])
  @@index([roomId])
}

model MatchResult {
  id            String              @id @default(cuid())
  matchNumber   Int
  winner        WinnerTeam
  civilianWord  String
  impostorWord  String
  createdAt     DateTime            @default(now())
  roomId        String
  room          Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playerResults MatchPlayerResult[]

  @@unique([roomId, matchNumber])
  @@index([roomId])
}

model MatchPlayerResult {
  id                String      @id @default(cuid())
  playerPublicId    String
  playerName        String
  role              PlayerRole
  receivedVoteCount Int
  votedForImpostor  Boolean
  isMatchWinner     Boolean
  matchResultId     String
  matchResult       MatchResult @relation(fields: [matchResultId], references: [id], onDelete: Cascade)

  @@unique([matchResultId, playerPublicId])
  @@index([matchResultId])
}
