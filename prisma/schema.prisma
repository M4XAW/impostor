generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoomPhase {
  LOBBY
  DISCUSSION
  VOTING
  RESULTS
}

enum PlayerRole {
  CIVILIAN
  IMPOSTOR
}

model Room {
  id          String    @id @default(cuid())
  code        String    @unique
  phase       RoomPhase @default(LOBBY)
  hostId      String?
  secretWord  String?
  wordCount   Int       @default(10)
  roundCount  Int       @default(3)
  turnSeconds Int       @default(30)
  impostorCount Int     @default(1)
  wordNumber  Int       @default(1)
  roundNumber Int       @default(1)
  currentPlayerIndex Int @default(0)
  turnEndsAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  players     Player[]
  votes       Vote[]
  clues       Clue[]
}

model Clue {
  id          String   @id @default(cuid())
  content     String
  wordNumber  Int
  roundNumber Int
  createdAt   DateTime @default(now())
  roomId      String
  playerId    String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId, wordNumber, roundNumber])
  @@index([roomId])
}

model Player {
  id        String     @id @default(cuid())
  name      String
  role      PlayerRole @default(CIVILIAN)
  isHost    Boolean    @default(false)
  createdAt DateTime   @default(now())
  roomId    String
  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  votes     Vote[]     @relation("Voter")
  received  Vote[]     @relation("Target")
  clues     Clue[]

  @@index([roomId])
}

model Vote {
  id        String   @id @default(cuid())
  roomId    String
  voterId   String
  targetId  String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  voter     Player   @relation("Voter", fields: [voterId], references: [id], onDelete: Cascade)
  target    Player   @relation("Target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([roomId, voterId])
  @@index([roomId])
}
